{
  "name": "easypoints-server",
  "version": "0.1.0",
  "private": true,
  "description": "EasyPoints hackathon MVP - NestJS backend",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 node --tls-max-v1.2 -r ts-node/register src/main.ts",
    "start:prod": "node dist/main",
    "test": "jest --config jest.config.ts --passWithNoTests",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:cov": "jest --config jest.config.ts --coverage"
  },
  "dependencies": {
    "@easypoints/shared": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@vendia/serverless-express": "^4.12.6",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "dotenv": "^17.3.1",
    "joi": "^17.11.0",
    "mongoose": "^8.0.3",
    "nanoid": "3",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.6.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
